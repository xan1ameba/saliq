{"n":112,"name":"Al-Ikhlaas","meaning":"Sincerity","arabic":"الإِخۡلَاصِ","ayahs":4,"type":"Meccan","verses":[{"n":1,"ar":"قُلْ هُوَ ٱللَّهُ أَحَدٌ","ru":"Скажи: «Он - Аллах Единый,","kk":"Ей, Мұхаммед! Айт: «Ол, Аллаһ Ахад Жалғыз\r","en":"Say, \"He is Allah, [who is] One,","tr":"Qul huwal laahu ahad"},{"n":2,"ar":"ٱللَّهُ ٱلصَّمَدُ","ru":"Аллах Самодостаточный.","kk":"Аллаһ ас-Самад Мұқтажсыз, ал барлық жаратылыс Оған мұқтаж\r","en":"Allah, the Eternal Refuge.","tr":"Allah hus-samad"},{"n":3,"ar":"لَمْ يَلِدْ وَلَمْ يُولَدْ","ru":"Он не родил и не был рожден,","kk":"Ол тумаған және туылмаған\r","en":"He neither begets nor is born,","tr":"Lam yalid wa lam yoolad"},{"n":4,"ar":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","ru":"и нет никого равного Ему».","kk":"әрі Оған ешкім тең емес\r","en":"Nor is there to Him any equivalent.\"","tr":"Wa lam yakul-lahu kufuwan ahad"}]}